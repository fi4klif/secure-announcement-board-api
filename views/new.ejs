<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Додати оголошення - Дошка оголошень</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <div class="container">
      <h1>📋 Дошка оголошень</h1>
      <p>Купуй, продавай, поділись - все в одному місці</p>
    </div>
  </header>

  <div class="container">
    <div class="form-section">
      <h1>✏️ Додати оголошення</h1>

      <form method="POST" action="/announcements">
        <!-- Category -->
        <div class="form-group">
          <label>Категорія *</label>
          <div class="radio-group">
            <div class="radio-option">
              <input 
                type="radio" 
                id="cat-sale" 
                name="category" 
                value="sale"
                <%= data?.category === 'sale' ? 'checked' : '' %>
                required
              >
              <label for="cat-sale">📦 Продаж</label>
            </div>
            <div class="radio-option">
              <input 
                type="radio" 
                id="cat-service" 
                name="category" 
                value="service"
                <%= data?.category === 'service' ? 'checked' : '' %>
              >
              <label for="cat-service">🔧 Послуги</label>
            </div>
            <div class="radio-option">
              <input 
                type="radio" 
                id="cat-job" 
                name="category" 
                value="job"
                <%= data?.category === 'job' ? 'checked' : '' %>
              >
              <label for="cat-job">💼 Робота</label>
            </div>
            <div class="radio-option">
              <input 
                type="radio" 
                id="cat-other" 
                name="category" 
                value="other"
                <%= data?.category === 'other' ? 'checked' : '' %>
              >
              <label for="cat-other">📌 Інше</label>
            </div>
          </div>
          <% if (errors.category) { %>
            <span class="error-message"><%= errors.category %></span>
          <% } %>
        </div>

        <!-- Title -->
        <div class="form-group">
          <label for="title">Назва *</label>
          <input 
            type="text" 
            id="title" 
            name="title" 
            placeholder="Коротка назва оголошення"
            value="<%= data?.title || '' %>"
            required
            minlength="5"
            maxlength="100"
          >
          <% if (errors.title) { %>
            <span class="error-message"><%= errors.title %></span>
          <% } %>
        </div>

        <!-- Description -->
        <div class="form-group">
          <label for="description">Опис *</label>
          <textarea 
            id="description" 
            name="description" 
            placeholder="Детальний опис оголошення..."
            required
            minlength="10"
          ><%= data?.description || '' %></textarea>
          <% if (errors.description) { %>
            <span class="error-message"><%= errors.description %></span>
          <% } %>
        </div>

        <!-- Price -->
        <div class="form-group">
          <label for="price">Ціна (грн) *</label>
          <input 
            type="number" 
            id="price" 
            name="price" 
            placeholder="0.00"
            value="<%= data?.price || '' %>"
            required
            min="0"
            step="0.01"
          >
          <% if (errors.price) { %>
            <span class="error-message"><%= errors.price %></span>
          <% } %>
        </div>

        <!-- Contact Info -->
        <div class="form-group">
          <label for="contactInfo">Контактна інформація *</label>
          <input 
            type="text" 
            id="contactInfo" 
            name="contactInfo" 
            placeholder="Email або телефон"
            value="<%= data?.contactInfo || '' %>"
            required
            minlength="5"
          >
          <% if (errors.contactInfo) { %>
            <span class="error-message"><%= errors.contactInfo %></span>
          <% } %>
        </div>

        <!-- Buttons -->
        <div class="button-group">
          <button type="submit">✓ Опублікувати</button>
          <a href="/" style="flex: 1; text-align: center; padding: 10px; background-color: #95a5a6; color: white; text-decoration: none; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
            Скасувати
          </a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
